{
  "version": 2,
  "builds": [
    {
      "src": "/api/index.php",
      "use": "@vercel/php"
    },
    {
      "src": "/public/(.*)",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*\\.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot|map|json|pdf|txt|xml|webmanifest|webp))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}